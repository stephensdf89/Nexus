# Creator Nexus Pro - Environment Variables Template
# For setup instructions, see QUICK_START.md

# Supabase - Get from https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3...

# Database URL - Get from Supabase → Settings → Database → Connection String
DATABASE_URL=postgresql://postgres:password@your-project.supabase.co:5432/postgres

# NextAuth - Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-min-32-chars

# NextAuth URL - Change for production deployment
NEXTAUTH_URL=http://localhost:3000

# Optional: OAuth Platform Credentials
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
