generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model PlatformToken {
  id                 String   @id @default(cuid())
  userId             String
  platform           String
  postpulseAccountId String
  accessToken        String
  refreshToken       String?
  expiresAt          DateTime
  connectedAt        DateTime @default(now())
}

model Card {
  id        String   @id @default(cuid())
  userId    String
  title     String
  niche     String?
  script    String?
  caption   String?
  mediaUrl  String?
  platforms String[] // e.g. ["instagram", "tiktok"]
  createdAt DateTime @default(now())
  genome    ContentGenome?
}

model PostPerformance {
  id        String   @id @default(cuid())
  userId    String
  cardId    String?
  platform  String
  postedAt  DateTime
  likes     Int?
  comments  Int?
  shares    Int?
  views     Int?
  watchTime Int?
  createdAt DateTime @default(now())
}

model BestTimeModel {
  id        String   @id @default(cuid())
  userId    String
  platform  String
  hour      Int      // 0-23
  score     Float    // learned performance weight
  updatedAt DateTime @default(now())

  @@unique([userId, platform, hour], name: "userId_platform_hour")
}

model ContentGenome {
  id                String   @id @default(cuid())
  cardId            String   @unique
  card              Card     @relation(fields: [cardId], references: [id])

  formatType        String?
  contentType       String?
  platformSuitability String?
  lengthCategory    String?
  tone              String?
  ctaType           String?
  topicCategory     String?
  subTopicCategory  String?
  seriesId          String?
  clusterId         String?

  engagementScore   Float?
  retentionScore    Float?
  viralityScore     Float?
  platformPerformance Json?
  audienceSegmentPerformance Json?
  postingTimePerformance Json?
  formatPerformance Json?

  hookType          String?
  openingPattern    String?
  pacingPattern     String?
  valueType         String?
  emotionProfile    String?

  growthPotentialScore      Float?
  seriesPotentialScore      Float?
  clusterExpansionScore     Float?
  repostPotentialScore      Float?
  doubleDownPotentialScore  Float?
  trendAlignmentScore       Float?
  audienceFitScore          Float?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
