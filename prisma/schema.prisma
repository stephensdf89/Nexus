generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PlatformToken {
  id                 String   @id @default(cuid())
  userId             String
  platform           String
  postpulseAccountId String
  accessToken        String
  refreshToken       String?
  expiresAt          DateTime
  connectedAt        DateTime @default(now())
}
